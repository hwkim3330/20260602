{
  "name": "packet-lab-manager-server",
  "version": "1.0.0",
  "description": "PacketLabManager Server — Ethernet packet generation, capture & scenario validation (Node.js; libpcap/cap with tcpdump fallback, Windows via Npcap)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "switch:deep-report": "node tools/switchDeepReport.js",
    "install-native": "npm install serialport cap --save-optional",
    "setup:windows-cap": "node tools/setup-cap-windows.js",
    "postinstall": "node tools/postinstall.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "serialport": "^13.0.0",
    "ws": "^8.16.0"
  },
  "optionalDependencies": {
    "cap": "^0.2.1"
  }
}
